<?xml version="1.0" encoding="UTF-8" ?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        require-authentication="anonymous-all">

    <!-- Transition to handle Party creation via the auto-create service -->
    <transition name="createParty">
        <service-call name="create#com.moqui.party.Party"/>
        <default-response url="."/>
    </transition>

    <!-- Transition to handle Person creation (for name fields) -->
    <transition name="createPerson">
        <actions>
            <service-call name="create#com.moqui.party.Party" in-map="[partyTypeEnumId:'PtyPerson']" out-map="partyOut"/>
            <service-call name="create#com.moqui.party.Person" in-map="context + [partyId:partyOut.partyId]"/>
        </actions>
        <default-response url="."/>
    </transition>

    <!-- Transition to handle Party Groups creation (for  group name field) -->
    <transition name="createPartyGroup">
        <actions>
            <service-call name="create#com.moqui.party.Party" in-map="[partyTypeEnumId:'PtyPartyGroup']" out-map="partyGroupOut"/>
            <service-call name="create#com.moqui.party.PartyGroup" in-map="context + [partyId:partyGroupOut.partyId]"/>
        </actions>
        <default-response url="."/>
    </transition>

    <widgets>
        <!--Title-->
        <label type="h1" text="Party List"/>

        <!-- Create Party Dialog -->
        <container-dialog id="CreatePartyDialog" button-text="Create Party">
            <form-single name="CreatePartyForm" transition="createParty">
                <!-- Auto-generate edit fields from the Party entity -->
                <auto-fields-entity entity-name="com.moqui.party.Party" field-type="edit"/>

                <!-- Hide partyId since it will be auto-generated by the framework -->
                <field name="partyId"><default-field><hidden/></default-field></field>

                <!-- Override partyTypeEnumId with a drop-down for better UX -->
                <field name="partyTypeEnumId"><default-field title="Party Type">
                    <drop-down>
                        <option key="PtyPerson" text="Person"/>
                        <option key="PtyPartyGroup" text="Party Group"/>
                    </drop-down>
                </default-field></field>

                <!-- Submit button -->
                <field name="submitButton"><default-field title="Create"><submit/></default-field></field>
            </form-single>
        </container-dialog>

        <!-- Create Person Dialog (includes name fields) -->
        <container-dialog id="CreatePersonDialog" button-text="Create Person">
            <form-single name="CreatePersonForm" transition="createPerson">
                <!-- Auto-generate edit fields from the Person entity for name -->
                <auto-fields-entity entity-name="com.moqui.party.Person" field-type="edit"/>

                <!-- Hide partyId since it will be auto-generated -->
                <field name="partyId"><default-field><hidden/></default-field></field>

                <!-- Explicit name fields for clarity -->
                <field name="firstName"><default-field title="First Name"><text-line size="30"/></default-field></field>
                <field name="lastName"><default-field title="Last Name"><text-line size="30"/></default-field></field>

                <!-- Submit button -->
                <field name="submitButton"><default-field title="Create Person"><submit/></default-field></field>
            </form-single>
        </container-dialog>

        <!-- Create Person Dialog (includes group name fields) -->
            <container-dialog id="createPartyGroupDialog" button-text="Create Group">
                <form-single name="createPartyGroupForm" transition="createPartyGroup">
                    <auto-fields-entity entity-name="com.moqui.party.PartyGroup" field-type="edit"/>

                    <field name="partyId"><default-field><hidden/></default-field></field>

                    <field name="groupName"><default-field title="Company Name"><text-line size="30"/></default-field></field>

                    <field name="submitButton"><default-field title="Create Group"><submit/></default-field></field>
                </form-single>
            </container-dialog>

        <!--Fetching data...-->
        <form-list name="PartyListForm" list="partyList">
            <entity-find entity-name="com.moqui.party.Party" list="partyList"/>
            <field name="partyId"><default-field><display/></default-field></field>
            <field name="partyTypeEnumId"><default-field title="Type"><display/></default-field></field>
            <field name="createdDate"><default-field title="Created Date"><display/></default-field></field>
        </form-list>

    </widgets>
</screen>